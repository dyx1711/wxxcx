<view class="page">
  <view class="top-actions">
    <button class="create-btn" bindtap="goCreate">新增设备工单</button>
  </view>

  <view class="status-tabs">
    <text
      wx:for="{{statusTabs}}"
      wx:key="key"
      class="status-tab {{status === item.key ? 'active' : ''}}"
      data-status="{{item.key}}"
      bindtap="switchStatus"
    >{{item.label}} ({{item.count}})</text>
  </view>

  <view class="type-tabs">
    <text
      wx:for="{{typeTabs}}"
      wx:key="key"
      class="type-tab {{repairType === item.key ? 'active' : ''}}"
      data-type="{{item.key}}"
      bindtap="switchType"
    >{{item.label}}</text>
  </view>

  <view class="order-list">
    <view wx:if="{{loading}}" class="loading">加载中...</view>

    <block wx:elif="{{orders.length}}">
      <view
        class="order-card card"
        wx:for="{{orders}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="goDetail"
      >
        <view class="order-top">
          <text class="order-type type-{{item.type}}">{{item.typeLabel}}{{item.priorityLabel ? ' · ' + item.priorityLabel : ''}}</text>
          <text class="order-deadline {{item.deadlineClass}}">{{item.deadline || '未设置'}} 截止</text>
        </view>
        <text class="order-name">{{item.title}}</text>
        <text class="order-meta">{{item.no}} · {{item.location || '未设置位置'}}</text>
        <view class="order-bottom">
          <text class="order-time">{{item.createdAt}} 创建</text>
          <text class="order-link">查看详情 ›</text>
        </view>
        <button
          wx:if="{{canManage && status === 'completed'}}"
          class="delete-order-btn"
          data-id="{{item.id}}"
          catchtap="deleteOrder"
        >删除</button>
      </view>
    </block>

    <view wx:else class="empty-wrap">
      <text class="empty-title">暂无{{repairType === 'repair' ? '维修' : '保养'}}工单</text>
    </view>
  </view>
</view>

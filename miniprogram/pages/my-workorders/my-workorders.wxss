.page {
  min-height: 100vh;
  background: #F5F5F5;
}

.top-actions {
  background: #fff;
  padding: 24rpx 32rpx 0;
}

.create-btn {
  margin: 0;
  background: #111827;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.create-btn::after {
  border: none;
}

.status-tabs {
  display: flex;
  gap: 16rpx;
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
  overflow-x: auto;
}

.type-tabs {
  display: flex;
  gap: 12rpx;
  background: #fff;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 14rpx;
  background: #F5F5F5;
  color: #6B7280;
  font-size: 24rpx;
}

.type-tab.active {
  background: #111827;
  color: #fff;
  font-weight: 600;
}

.status-tab {
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: #F5F5F5;
  color: #4B5563;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-tab.active {
  background: #1E90FF;
  color: #fff;
  font-weight: 500;
}

.order-list {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card:active {
  opacity: 0.8;
}

.order-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.order-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.type-repair {
  background: #FEF2F2;
  color: #EF4444;
}

.type-maintain {
  background: #FFF7ED;
  color: #F97316;
}

.order-deadline {
  font-size: 24rpx;
}

.order-deadline.danger { color: #EF4444; }
.order-deadline.warning { color: #F97316; }
.order-deadline.muted { color: #6B7280; }

.order-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
  display: block;
}

.order-meta {
  font-size: 24rpx;
  color: #6B7280;
  display: block;
  margin-top: 8rpx;
}

.order-bottom {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F9FAFB;
}

.order-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.order-link {
  font-size: 24rpx;
  color: #1E90FF;
  font-weight: 500;
}

.delete-order-btn {
  margin: 20rpx 0 0;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 12rpx;
  background: #FEF2F2;
  color: #DC2626;
  font-size: 24rpx;
}

.delete-order-btn::after {
  border: none;
}

.loading {
  text-align: center;
  padding: 48rpx;
  color: #9CA3AF;
}

.empty-wrap {
  text-align: center;
  padding: 120rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #9CA3AF;
}

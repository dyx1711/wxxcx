.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx 32rpx 160rpx;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 32rpx;
}

.field {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.field:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

input,
.picker {
  font-size: 28rpx;
  color: #111827;
  min-height: 48rpx;
}

textarea {
  width: 100%;
  min-height: 220rpx;
  font-size: 28rpx;
  color: #111827;
}

.file-btn {
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  background: #EFF6FF;
  color: #1E90FF;
  font-size: 26rpx;
}

.file-btn::after {
  border: none;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F3F4F6;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.72);
  color: #fff;
  font-size: 20rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #F3F4F6;
}

.save-btn {
  background: #111827;
  color: #fff;
  border-radius: 16rpx;
}

.save-btn::after {
  border: none;
}

.loading {
  text-align: center;
  padding: 120rpx;
  color: #9CA3AF;
}

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.guest-header {
  background: #fff;
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-bottom: 1rpx solid #F3F4F6;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-icon {
  font-size: 80rpx;
}

.login-btn {
  background: #1E90FF;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 64rpx;
  border-radius: 999rpx;
  border: none;
  line-height: normal;
}

.login-btn::after {
  border: none;
}

.login-tip {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 24rpx;
}

.menu-disabled {
  padding: 32rpx;
}

.menu-disabled .menu-item {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 0;
}

.menu-disabled .menu-item:first-child {
  border-radius: 24rpx 24rpx 0 0;
}

.menu-disabled .menu-item:last-child {
  border-radius: 0 0 24rpx 24rpx;
}

.user-header {
  background: linear-gradient(135deg, #1E90FF, #2563EB);
  padding: 48rpx 32rpx 64rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 600;
}

.user-info {
  color: #fff;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.user-dept {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-top: 4rpx;
}

.role-badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  margin-top: 16rpx;
}

.menu-section {
  padding: 0 32rpx;
  margin-top: -32rpx;
}

.menu-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F9FAFB;
}

.menu-item.no-border {
  border-bottom: none;
}

.menu-item:active {
  background: #F9FAFB;
}

.menu-item.disabled {
  opacity: 0.5;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon.blue { background: #EFF6FF; }
.menu-icon.orange { background: #FFF7ED; }
.menu-icon.green { background: #F0FDF4; }
.menu-icon.purple { background: #FAF5FF; }
.menu-icon.gray { background: #F3F4F6; }
.menu-icon.gray-dark { background: #F3F4F6; }

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
  display: block;
}

.menu-title.flex1 {
  flex: 1;
}

.menu-sub {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
  display: block;
}

.menu-text.gray {
  font-size: 28rpx;
  color: #9CA3AF;
}

.arrow {
  font-size: 32rpx;
  color: #D1D5DB;
}

.subscribe-state {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.subscribe-state.on {
  color: #15803D;
  background: #DCFCE7;
}

.subscribe-state.off {
  color: #2563EB;
  background: #DBEAFE;
}

.logout-btn {
  width: 100%;
  background: #fff;
  color: #EF4444;
  font-size: 28rpx;
  font-weight: 500;
  padding: 28rpx;
  border-radius: 24rpx;
  border: none;
  line-height: normal;
  margin-top: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.logout-btn::after {
  border: none;
}

.copyright {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  padding: 32rpx 0;
}

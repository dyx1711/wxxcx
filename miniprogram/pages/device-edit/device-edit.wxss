.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx 32rpx 160rpx;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 32rpx;
}

.field {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.field:last-child {
  border-bottom: none;
}

.field.two {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

input,
.picker {
  font-size: 28rpx;
  color: #111827;
  min-height: 48rpx;
}

textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 28rpx;
  color: #111827;
}

.image-btn {
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  background: #EFF6FF;
  color: #1E90FF;
  font-size: 26rpx;
}

.image-btn::after {
  border: none;
}

.file-btn {
  margin: 16rpx 0 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  background: #F0FDF4;
  color: #16A34A;
  font-size: 26rpx;
}

.file-btn::after {
  border: none;
}

.guide-file-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.guide-file {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #F9FAFB;
}

.guide-file-name {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guide-file-remove {
  color: #DC2626;
  font-size: 24rpx;
  flex-shrink: 0;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F3F4F6;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.cover-badge,
.cover-action,
.image-remove {
  position: absolute;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 20rpx;
}

.cover-badge {
  left: 8rpx;
  top: 8rpx;
  background: rgba(30, 144, 255, 0.88);
}

.cover-action {
  left: 8rpx;
  top: 8rpx;
  background: rgba(17, 24, 39, 0.72);
}

.image-remove {
  right: 8rpx;
  top: 8rpx;
  background: rgba(220, 38, 38, 0.82);
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #F3F4F6;
  display: grid;
  gap: 16rpx;
}

.footer.two {
  grid-template-columns: 1fr 1fr;
}

.save-btn,
.delete-btn {
  background: #111827;
  color: #fff;
  border-radius: 16rpx;
}

.delete-btn {
  background: #FEF2F2;
  color: #DC2626;
}

.save-btn::after,
.delete-btn::after {
  border: none;
}

.loading {
  text-align: center;
  padding: 120rpx;
  color: #9CA3AF;
}

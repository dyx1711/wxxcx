.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #F3F4F6;
  padding-bottom: env(safe-area-inset-bottom);
  padding-top: 12rpx;
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding-bottom: 8rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #9CA3AF;
}

.tab-item.active .tab-text {
  color: #1E90FF;
  font-weight: 500;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  opacity: 0.5;
}

.tab-item.active .tab-icon {
  opacity: 1;
}

